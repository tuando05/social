{
  "info": {
    "name": "Social Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for testing Social backend endpoints."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /api/users/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          }
        },
        {
          "name": "PATCH /api/users/me",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Demo User\",\n  \"bio\": \"Hello world\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          }
        },
        {
          "name": "POST /api/users/:userId/follow",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{targetUserId}}/follow",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{targetUserId}}", "follow"]
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "POST /api/posts",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Post from Postman\",\n  \"imageUrls\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"]
            }
          }
        },
        {
          "name": "GET /api/posts/feed",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/posts/feed?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "feed"],
              "query": [
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "POST /api/comments/post/:postId",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Great post!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/comments/post/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "post", "{{postId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "GET /api/search",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/search?q=demo&type=all&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search"],
              "query": [
                { "key": "q", "value": "demo" },
                { "key": "type", "value": "all" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "GET /api/notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notifications?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "PATCH /api/notifications/read-all",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clerkToken}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "read-all"]
            }
          }
        }
      ]
    },
    {
      "name": "Docs",
      "item": [
        {
          "name": "GET /api/docs/json",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/docs/json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "docs", "json"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "clerkToken", "value": "" },
    { "key": "targetUserId", "value": "" },
    { "key": "postId", "value": "" }
  ]
}
